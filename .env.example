# ─── BabyDoge BTC Oracle — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — .gitignore should already exclude it.

# ── Polymarket Builder API Key ────────────────────────────────────────────────
# Found at: polymarket.com → Settings → Builder Codes → API Key
# Used for: authenticated CLOB endpoints (order placement, builder analytics)
# Public endpoints (price, spread, history) work WITHOUT this key.
VITE_POLY_API_KEY=019cdb75-66b0-73f6-a79b-993d15f132b2

# ── Your Polymarket Wallet Address ────────────────────────────────────────────
# Found at: polymarket.com → Settings → Builder Codes → Address
# Used as the POLY-ADDRESS header for authenticated requests
VITE_POLY_ADDRESS=0x3a5a392c0892ae5efd7f7bad59e6e7a175725b33

# ── Optional: Builder Tag ─────────────────────────────────────────────────────
# Appended to orders so Polymarket attributes volume to your builder account
# Earns you a share of protocol fees on matched orders
VITE_POLY_BUILDER_TAG=babydoge-btc-oracle
